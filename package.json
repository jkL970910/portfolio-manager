{
    "name":  "portfolio-manager",
    "version":  "0.1.0",
    "private":  true,
    "scripts":  {
                    "dev":  "next dev",
                    "build":  "next build",
                    "start":  "next start",
                    "lint":  "eslint .",
                    "typecheck":  "next typegen \u0026\u0026 tsc --noEmit",
                    "local:start":  "powershell -ExecutionPolicy Bypass -File ./scripts/local-start.ps1",
                    "local:setup":  "powershell -ExecutionPolicy Bypass -File ./scripts/local-start.ps1 -SkipDevServer",
                    "local:reset":  "powershell -ExecutionPolicy Bypass -File ./scripts/local-start.ps1 -SkipDevServer -ForceSeed",
                    "db:init":  "powershell -ExecutionPolicy Bypass -File ./scripts/init-local-postgres.ps1",
                    "db:start":  "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-postgres.ps1",
                    "db:stop":  "powershell -ExecutionPolicy Bypass -File ./scripts/stop-local-postgres.ps1",
                    "db:generate":  "drizzle-kit generate",
                    "db:push":  "drizzle-kit push",
                    "db:seed":  "powershell -ExecutionPolicy Bypass -File ./scripts/seed-local-db.ps1",
                    "local:start:linux":  "bash ./scripts/local-start.sh",
                    "db:seed:linux":  "bash ./scripts/seed-local-db.sh",
                    "dev:host":  "next dev -H 0.0.0.0",
                    "preview:start":  "npm run dev:host",
                    "preview:tunnel:cloudflare":  "bash ./scripts/start-cloudflare-tunnel.sh",
                    "mobile:pub:get":  "cd apps/mobile && flutter pub get",
                    "mobile:dev:web":  "bash ./scripts/start-flutter-mobile.sh",
                    "mobile:preview:proxy":  "node ./scripts/mobile-preview-proxy.mjs",
                    "remote:ductor":  "bash ./scripts/start-ductor.sh",
                    "remote:stack:start":  "bash ./scripts/start-remote-dev-stack.sh",
                    "remote:stack:stop":  "bash ./scripts/stop-remote-dev-stack.sh",
                    "remote:stack:attach":  "tmux attach -t portfolio-remote-dev",
                    "remote:stack:status":  "bash ./scripts/status-remote-dev-stack.sh"
                },
    "dependencies":  {
                         "bcryptjs":  "^3.0.3",
                         "class-variance-authority":  "^0.7.1",
                         "clsx":  "^2.1.1",
                         "drizzle-kit":  "^0.31.10",
                         "drizzle-orm":  "^0.45.1",
                         "lucide-react":  "^0.544.0",
                         "next":  "^15.5.3",
                         "next-auth":  "^5.0.0-beta.30",
                         "pg":  "^8.20.0",
                         "react":  "^19.1.1",
                         "react-dom":  "^19.1.1",
                         "recharts":  "^3.1.2",
                         "tailwind-merge":  "^3.3.1",
                         "zod":  "^4.3.6"
                     },
    "devDependencies":  {
                            "@tailwindcss/postcss":  "^4.1.13",
                            "@types/node":  "^24.3.0",
                            "@types/pg":  "^8.18.0",
                            "@types/react":  "^19.1.12",
                            "@types/react-dom":  "^19.1.9",
                            "dotenv":  "^17.4.2",
                            "eslint":  "^9.34.0",
                            "eslint-config-next":  "^15.5.3",
                            "tailwindcss":  "^4.1.13",
                            "typescript":  "^5.9.2"
                        }
}
